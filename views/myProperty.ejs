<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Home Page</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="stylesheet" href="/vendor/normalize-4.1.1.css" type="text/css" />
    <link rel="stylesheet" href="/vendor/border-box.css" type="text/css" />
    <link rel="stylesheet" href="/styles/main.css" type="text/css" />
    <link rel="stylesheet" href="/styles/layout.css" type="text/css" />
    <!-- Header styles -->
    <link rel="stylesheet" href="/styles/header.css" type="text/css" />
    <!-- Page styles -->
    <link rel="stylesheet" href="/styles/properties.css" type="text/css" />
    <!-- Bootstrap CSS -->
    <link
      rel="stylesheet"
      href="https://stackpath.bootstrapcdn.com/bootstrap/4.2.1/css/bootstrap.min.css"
      integrity="sha384-GJzZqFGwb1QTTN6wy59ffF1BuGJpLSa9DkKMp0DgiMDm4iYMj70gZWKYbI706tWS"
      crossorigin="anonymous"
    />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha512-Fo3rlrZj/k7ujTnHg4CGR2D7kSs0v4LLanw2qksYuRlEzO+tcaEPQogQ0KaoGN26/zrn20ImR1DfuLWnOo7aBA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script type="text/javascript" src="/vendor/jquery-3.0.0.js"></script>

  </head>

  <body>
    <header id="header"><%-include('partials/_header') %></header>
    <main id="main">
      <h3 class='text-center'>My Properties</h3>

      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <% for(const property in myProperty) { %>
        <div class="col">
          <div id="<%= myProperty[property].id%>" class="card h-100">
            <img src="<%= myProperty[property].image_url %>" class="card-img-top" alt="<%= myProperty[property].name %>" loading="lazy" width="400" height="260" />
            <div class="card-body">
              <h5 class="card-title"><%= myProperty[property].name %></h5>
              <p class="card-text"><%= myProperty[property].description %></p>
              <p class="card-text text-muted">Bed: <%= myProperty[property].number_of_bedrooms %> <span>Bath: <%= myProperty[property].number_of_bathrooms %></span></p>
              <div class="card-text d-flex justify-content-between">
                <span class="cost">$<%= myProperty[property].cost %></span>
                <div class="property-actions">
                  <button type="button" class="property-action update" data-id="<%= myProperty[property].id %>" aria-label="Mark <%= myProperty[property].name %> as sold">
                    <i class="fas fa-money-check-alt" aria-hidden="true"></i>
                  </button>
                  <button type="button" class="property-action delete" data-id="<%= myProperty[property].id %>" aria-label="Delete <%= myProperty[property].name %>">
                    <i class="fas fa-trash-alt" aria-hidden="true"></i>
                  </button>
                </div>

              </div>
            </div>
          </div>
        </div>
        <% } %>
      </div>
    </main>

    <!-- Scripts -->
    <script src="./scripts/app.js"></script>
    <!-- Bootstrap Script -->
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
