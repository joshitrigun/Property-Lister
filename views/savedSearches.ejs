<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Saved Searches - Property Lister</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="/vendor/normalize-4.1.1.css" type="text/css" />
    <link rel="stylesheet" href="/vendor/border-box.css" type="text/css" />
    <link rel="stylesheet" href="/styles/main.css" type="text/css" />
    <link rel="stylesheet" href="/styles/layout.css" type="text/css" />
    <link rel="stylesheet" href="/styles/header.css" type="text/css" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.2.1/css/bootstrap.min.css" integrity="sha384-GJzZqFGwb1QTTN6wy59ffF1BuGJpLSa9DkKMp0DgiMDm4iYMj70gZWKYbI706tWS" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha512-Fo3rlrZj/k7ujTnHg4CGR2D7kSs0v4LLanw2qksYuRlEzO+tcaEPQogQ0KaoGN26/zrn20ImR1DfuLWnOo7aBA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  </head>

  <body>
    <header id="header"><%-include('partials/_header') %></header>
    <main id="main" class="container py-4">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-bookmark me-2"></i>Saved Searches</h2>
        <a href="/properties" class="btn btn-outline-primary btn-sm">
          <i class="fas fa-search"></i> Browse listings
        </a>
      </div>

      <% if (searches.length === 0) { %>
      <div class="text-center text-muted py-5">
        <i class="fas fa-bookmark fa-3x mb-3 d-block" style="opacity:0.3"></i>
        <p>You haven't saved any searches yet.</p>
        <a href="/properties" class="btn btn-primary">Start browsing</a>
      </div>
      <% } else { %>
      <div class="list-group saved-searches-list">
        <% searches.forEach(function(s) { %>
        <div class="list-group-item list-group-item-action saved-search-item d-flex justify-content-between align-items-center">
          <div>
            <a href="/properties?<%= s.query_params %>" class="saved-search-name fw-semibold">
              <i class="fas fa-search me-1 text-muted"></i><%= s.name %>
            </a>
            <div class="saved-search-meta text-muted small mt-1">
              Saved <%= new Date(s.created_at).toLocaleDateString('en-CA', { year:'numeric', month:'short', day:'numeric' }) %>
              &nbsp;&middot;&nbsp;
              <a href="/properties?<%= s.query_params %>" class="text-muted">
                /properties?<%= s.query_params.length > 60 ? s.query_params.slice(0,60) + '…' : s.query_params %>
              </a>
            </div>
          </div>
          <form action="/saved-searches/<%= s.id %>/delete" method="POST" class="ms-3 flex-shrink-0">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete this saved search"
              onclick="return confirm('Remove this saved search?')">
              <i class="fas fa-trash-alt"></i>
            </button>
          </form>
        </div>
        <% }); %>
      </div>
      <% } %>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p" crossorigin="anonymous"></script>
  </body>
</html>
